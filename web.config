<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <directoryBrowse enabled="false" />
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="classes" />
          <add segment="app" />
          <add segment="inc" />
          <add segment="logs" />
          <add segment="uploads" />
          <add segment="storage" />
          <add segment="scripts" />
          <add segment="templates" />
          <add segment="docs" />
          <add segment="deployment" />
          <add segment="chrome-extension" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".sql" allowed="false" />
          <add fileExtension=".log" allowed="false" />
          <add fileExtension=".bak" allowed="false" />
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".lnk" allowed="false" />
          <add fileExtension=".pem" allowed="false" />
          <add fileExtension=".key" allowed="false" />
          <add fileExtension=".conf" allowed="false" />
          <add fileExtension=".config" allowed="false" />
          <add fileExtension=".md" allowed="false" />
          <add fileExtension=".ps1" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
