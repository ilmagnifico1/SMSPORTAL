Options -Indexes
ServerSignature Off

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(?:src|storage)(?:/|$) - [F,L,NC]
    RewriteRule ^(?:config(?:\.local)?|router|selftest)\.php$ - [F,L,NC]
    RewriteRule ^(?:README\.md|web\.config|.*\.example)$ - [F,L,NC]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ public/index.php [L,QSA]
</IfModule>
