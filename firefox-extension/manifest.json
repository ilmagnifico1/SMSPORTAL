{
  "manifest_version": 3,
  "name": "SMS Portal - Autorizzazione dispositivo",
  "version": "1.1.0",
  "description": "Autorizza gli invii SMS con una firma crittografica legata al dispositivo Firefox registrato.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "windows"],
  "host_permissions": [
    "https://smsportal.book-my.eu/*"
  ],
  "background": {
    "scripts": ["service-worker.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://smsportal.book-my.eu/*"
      ],
      "js": ["content-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "SMS Portal - dispositivo protetto",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "sms-portal@book-my.eu",
      "strict_min_version": "121.0"
    }
  }
}
